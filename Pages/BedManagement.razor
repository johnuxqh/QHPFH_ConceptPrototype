@page "/bed-management"
@using Microsoft.AspNetCore.Components.Web
@using MudBlazor

<section class="page-shell-card bed-mgmt-page" aria-label="Bed management ward operations">
    @if (!string.IsNullOrWhiteSpace(_toastMessage))
    {
        <div class="bm-toast">@_toastMessage</div>
    }

    <div class="bm-filter-row">
        <div class="bm-filter"><span>Facility:</span><button type="button">QCH</button></div>
        <div class="bm-filter"><span>HHS:</span><button type="button">All</button></div>
        <div class="bm-filter"><span>Ward:</span><button type="button">8A Surgical</button></div>
        <button class="bm-allocation-btn" type="button" @onclick="() => _isAllocationPanelOpen = true">View Allocation Board</button>
    </div>

    <section class="bm-view-tabs" role="tablist" aria-label="View mode">
        @foreach (var view in ViewModes)
        {
            <button type="button" class="bm-tab @(view == SelectedView ? "active" : null)" @onclick="() => SelectedView = view">@view</button>
        }
    </section>

    <section class="bm-summary-strip">
        @foreach (var item in SummaryItems)
        {
            <article class="bm-summary-item">
                <p>@item.Label</p>
                <strong class="@item.ToneClass">@item.Value</strong>
            </article>
        }
    </section>

    <section class="bm-events-strip">
        <h3>Active Operational Events</h3>
        <ul>
            @foreach (var evt in OperationalEvents)
            {
                <li><span class="bm-event-location">@evt.Location</span><span>@evt.Message</span></li>
            }
        </ul>
    </section>

    <div class="bm-main-grid">
        <section class="bm-list-panel">
            @if (SelectedView == "List View")
            {
                <table class="bm-bay-table">
                    <thead>
                        <tr>
                            <th>Ward / Bay</th><th>Beds Total</th><th>Occupied</th><th>Ready</th><th>Cleaning</th><th>Blocked</th><th>Maintenance</th><th>Key Notes</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var bay in Bays)
                        {
                            <tr class="bm-group-row" @onclick="() => ToggleBay(bay.BayName)">
                                <td><button class="bm-expand" type="button"><MudIcon Icon="@(bay.IsExpanded ? Icons.Material.Outlined.ExpandLess : Icons.Material.Outlined.ExpandMore)" Size="Size.Small" />@bay.BayName</button></td>
                                <td>@bay.TotalBeds</td><td>@bay.Occupied</td><td>@bay.Ready</td><td>@bay.Cleaning</td><td>@bay.Blocked</td><td>@bay.Maintenance</td><td>@bay.KeyNotes</td>
                            </tr>
                            @if (bay.IsExpanded)
                            {
                                @foreach (var bed in bay.Beds)
                                {
                                    <tr class="bm-bed-row @(bed.Status == "Ready" ? "drop-ready" : null)" @ondragover="AllowDrop" @ondrop="(e) => DropPatientToBed(bay, bed)">
                                        <td class="bm-bed-cell">@bed.BedNumber</td>
                                        <td colspan="2">
                                            @if (bed.Status == "Occupied")
                                            {
                                                <div class="bm-bed-patient" draggable="true" @ondragstart="() => StartDragFromBed(bay, bed)">@bed.PatientName</div>
                                            }
                                            else { @bed.PatientName }
                                        </td>
                                        <td>@bed.AgeSex</td>
                                        <td><span class="bm-status @bed.StatusClass">@bed.Status</span></td>
                                        <td>@bed.Specialty</td><td>@bed.Los</td><td class="bm-bed-note">@bed.Notes <MudIcon Icon="@Icons.Material.Outlined.MoreHoriz" Size="Size.Small" /></td>
                                    </tr>
                                }
                            }
                        }
                    </tbody>
                </table>
            }
            else if (SelectedView == "Grid View")
            {
                <div class="bm-grid-view">
                    @foreach (var bay in Bays)
                    {
                        <article class="bm-bay-card">
                            <header>
                                <h4>@bay.BayName</h4>
                                <span>@bay.Occupied/@bay.TotalBeds occupied</span>
                            </header>
                            <div class="bm-bed-tiles bm-cols-@bay.TotalBeds">
                                @foreach (var bed in bay.Beds)
                                {
                                    <div class="bm-bed-tile @(bed.Status == "Ready" ? "drop-ready" : null)" @ondragover="AllowDrop" @ondrop="(e) => DropPatientToBed(bay, bed)">
                                        <div class="bm-bed-tile-head">
                                            <strong>@bed.BedNumber</strong>
                                            <span class="bm-status @bed.StatusClass">@bed.Status</span>
                                        </div>
                                        @if (bed.Status == "Occupied")
                                        {
                                            <div class="bm-bed-patient" draggable="true" @ondragstart="() => StartDragFromBed(bay, bed)">@bed.PatientName</div>
                                        }
                                        else
                                        {
                                            <div class="bm-bed-empty">Ready for allocation</div>
                                        }
                                        <div class="bm-bed-note-short">@ShortNoteFor(bed)</div>
                                    </div>
                                }
                            </div>
                        </article>
                    }
                </div>
            }
            else if (SelectedView == "Map View")
            {
                <div class="bm-map-layout">
                    <div class="bm-zone bm-corridor">Main Corridor</div>
                    <div class="bm-zone bm-staff">Staff Station</div>
                    <div class="bm-zone bm-treatment">Treatment Room</div>
                    <div class="bm-zone bm-clean">Clean Utility</div>
                    <div class="bm-zone bm-soiled">Soiled Utility</div>
                    <div class="bm-zone bm-store">Store Room</div>

                    @foreach (var bay in Bays)
                    {
                        <section class="bm-map-bay bm-map-bay-@bay.BayName.Replace(" ", "").ToLowerInvariant()">
                            <header>@bay.BayName</header>
                            <div class="bm-map-beds bm-cols-@bay.TotalBeds">
                                @foreach (var bed in bay.Beds)
                                {
                                    var isIsolation = bed.Notes.Contains("isolation", StringComparison.OrdinalIgnoreCase);
                                    <div class="bm-map-bed @(bed.Status == "Ready" ? "drop-ready" : null)"
                                         @ondragover="AllowDrop"
                                         @ondrop="(e) => DropPatientToBed(bay, bed)">
                                        <div class="bm-map-bed-top">
                                            <span>@bed.BedNumber</span>
                                            <span class="bm-status @bed.StatusClass">@(isIsolation ? "Isolation" : bed.Status)</span>
                                        </div>
                                        @if (bed.Status == "Occupied")
                                        {
                                            <div class="bm-bed-patient" draggable="true" @ondragstart="() => StartDragFromBed(bay, bed)">@bed.PatientName</div>
                                        }
                                        else
                                        {
                                            <div class="bm-bed-empty">@((bed.Status == "Ready") ? "Ready" : "Unavailable")</div>
                                        }
                                    </div>
                                }
                            </div>
                        </section>
                    }
                </div>
            }
            else
            {
                <div class="bm-placeholder">@SelectedView placeholder ready for next implementation pass.</div>
            }
        </section>

        <aside class="bm-right-panel">
            <article>
                <h4>Incoming</h4>
                <ul>
                    <li>ED Arrivals: 3</li>
                    <li>Add On Patients: 2</li>
                    <li>IHT Returns: 1</li>
                </ul>
            </article>
            <article>
                <h4>Quick Actions</h4>
                <div class="bm-actions">
                    @foreach (var action in QuickActions)
                    {
                        <button type="button">@action</button>
                    }
                </div>
            </article>
            <article>
                <h4>Recent Activity</h4>
                <ul class="bm-activity">
                    <li>12:20 Bay 3 Bed 2 flagged blocked. NUM note added.</li>
                    <li>12:05 Bay 5 Bed 1 changed from cleaning to ready.</li>
                    <li>11:42 Facilities confirmed Bay 6 maintenance booking.</li>
                    <li>11:18 ED called ahead for 1 surgical admission.</li>
                </ul>
            </article>
        </aside>
    </div>
</section>

@if (_isAllocationPanelOpen)
{
    <div class="bm-slideout-backdrop" @onclick="() => _isAllocationPanelOpen = false"></div>
    <aside class="bm-slideout" @ondragover="AllowDrop">
        <header>
            <h3>@(_dragMode == "bed" ? "Move Patient To" : "Allocation Board")</h3>
            <button type="button" @onclick="() => _isAllocationPanelOpen = false">Close</button>
        </header>

        @if (_dragMode == "bed")
        {
            <div class="bm-targets">
                @foreach (var target in MoveTargets)
                {
                    <div class="bm-move-target" @ondrop="(e) => DropFromBedToTarget(target)">@target</div>
                }
            </div>
        }
        else
        {
            <div class="bm-allocation-tabs">
                @foreach (var tab in AllocationTabs)
                {
                    <button class="@(SelectedAllocationTab == tab ? "active" : null)" @onclick="() => SelectedAllocationTab = tab">@tab</button>
                }
            </div>

            <div class="bm-cards">
                @foreach (var patient in AllocationBySource[SelectedAllocationTab])
                {
                    <article class="bm-patient-card" draggable="true" @ondragstart="() => StartDragFromAllocation(patient)">
                        <strong>@patient.Name</strong>
                        <p>@patient.AgeSex • @patient.Presentation</p>
                        <p>
                            ETA @patient.Eta
                            @if (!string.IsNullOrWhiteSpace(patient.Needs))
                            {
                                <span> • Needs @patient.Needs</span>
                            }
                        </p>
                        @if (!string.IsNullOrWhiteSpace(patient.Priority))
                        {
                            <span class="bm-priority">Priority @patient.Priority</span>
                        }
                    </article>
                }
            </div>
        }
    </aside>
}

@code {
    private bool _isAllocationPanelOpen;
    private string? _toastMessage;
    private string _dragMode = "";
    private PatientCard? _draggedAllocationPatient;
    private (BayOperation bay, BedOperation bed)? _draggedBedPatient;

    private string SelectedView { get; set; } = "List View";
    private static readonly List<string> ViewModes = ["List View", "Grid View", "Map View"];

    private string SelectedAllocationTab { get; set; } = "ED";
    private static readonly List<string> AllocationTabs = ["ED", "OPD", "IHT", "Other"];
    private static readonly List<string> MoveTargets = ["IHT Returns", "Pending Transfer", "Temporary Hold", "Discharge Pending"];

    private Dictionary<string, List<PatientCard>> AllocationBySource = new()
    {
        ["ED"] =
        [
            new("Jake Martin", "9 yrs, M", "Abdominal Pain", "15m", "Standard", "High"),
            new("Chloe Davis", "4 yrs, F", "Asthma Exacerbation", "25m", "Oxygen", "Medium"),
            new("Ethan Brown", "7 yrs, M", "Fracture Forearm", "30m", "Orthopaedic", "Medium"),
            new("Mia Wilson", "5 yrs, F", "Vomiting / Dehydration", "45m", "Standard", "Low")
        ],
        ["OPD"] = [new("Ava Collins", "6 yrs, F", "OPD conversion", "1h", "", "")],
        ["IHT"] =
        [
            new("Jack Thompson", "65 yrs, M", "Cardiology", "45m", "Telemetry", ""),
            new("Scarlett Nguyen", "72 yrs, F", "General Medicine", "2h", "Standard", "")
        ],
        ["Other"] = []
    };

    private static readonly List<(string Label, string Value, string ToneClass)> SummaryItems =
    [
        ("Total Beds", "48", "tone-neutral"),
        ("Occupied", "32", "tone-occupied"),
        ("Ready", "8", "tone-ready"),
        ("Cleaning", "4", "tone-cleaning"),
        ("Blocked", "3", "tone-blocked"),
        ("Maintenance", "1", "tone-maintenance"),
        ("System Pressure", "19%, Low", "tone-low")
    ];

    private static readonly List<(string Location, string Message)> OperationalEvents =
    [
        ("Bay 3", "Bed 2 blocked due to adjacent aggressive patient, review after meds"),
        ("Bay 6", "Maintenance until 14:00, facilities booked"),
        ("Isolation", "Bay 1 Bed 1 occupied by non-isolation patient")
    ];

    private static readonly List<string> QuickActions =
    ["Block Bed", "Mark Cleaning", "Mark Ready", "Request Maintenance", "Add Operational Note"];

    private readonly List<BayOperation> Bays =
    [
        new("Bay 1", 2, 2, 0, 0, 0, 0, "Isolation allocation mismatch", true, [new("Bed 1", "Alex Browne", "67M", "Occupied", "occupied", "General Surgery", "2d", "Non-isolation patient"), new("Bed 2", "Priya Das", "54F", "Occupied", "occupied", "General Surgery", "1d", "Stable")]),
        new("Bay 2", 3, 2, 1, 0, 0, 0, "One bed ready", false, [new("Bed 1", "Mila Torres", "39F", "Occupied", "occupied", "Breast Surgery", "3d", "Awaiting imaging"), new("Bed 2", "", "", "Ready", "ready", "-", "-", "Prepared"), new("Bed 3", "Tom Willis", "71M", "Occupied", "occupied", "Urology", "1d", "Post-op day 1")]),
        new("Bay 3", 4, 2, 1, 0, 1, 0, "Bed 2 blocked", false, [new("Bed 1", "Jordan Lee", "61M", "Occupied", "occupied", "Colorectal", "4d", "Pain review 14:00"), new("Bed 2", "", "", "Blocked", "blocked", "-", "-", "Adjacent behaviour risk"), new("Bed 3", "Nadia Khan", "45F", "Occupied", "occupied", "General Surgery", "2d", "Mobilising"), new("Bed 4", "", "", "Ready", "ready", "-", "-", "Available")]),
        new("Bay 4", 3, 2, 0, 1, 0, 0, "Cleaning in progress", false, [new("Bed 1", "Luca James", "58M", "Occupied", "occupied", "Vascular", "3d", "Drain monitoring"), new("Bed 2", "Rina Patel", "48F", "Occupied", "occupied", "General Surgery", "1d", "Pain controlled"), new("Bed 3", "", "", "Cleaning", "cleaning", "-", "-", "EVS assigned")]),
        new("Bay 5", 2, 1, 1, 0, 0, 0, "Ready for admit", false, [new("Bed 1", "Dana Cook", "69F", "Occupied", "occupied", "ENT", "5d", "Discharge likely tomorrow"), new("Bed 2", "", "", "Ready", "ready", "-", "-", "Bed made")]),
        new("Bay 6", 2, 1, 0, 0, 0, 1, "Maintenance booked", false, [new("Bed 1", "Samir Gill", "52M", "Occupied", "occupied", "General Surgery", "2d", "Nil acute issues"), new("Bed 2", "", "", "Maintenance", "maintenance", "-", "-", "Out of service till 14:00")]),
        new("Bay 7", 3, 2, 1, 0, 0, 0, "One ready", false, []),
        new("Bay 8", 3, 2, 1, 0, 0, 0, "One ready", false, []),
        new("Bay 9", 4, 3, 0, 1, 0, 0, "One cleaning", false, []),
        new("Bay 10", 3, 2, 1, 0, 0, 0, "One ready", false, [])
    ];


    private static string ShortNoteFor(BedOperation bed)
    {
        if (bed.Notes.Contains("isolation", StringComparison.OrdinalIgnoreCase)) return "Isolation";
        if (bed.Notes.Contains("EVS", StringComparison.OrdinalIgnoreCase)) return "EVS requested";
        if (bed.Notes.Contains("hold", StringComparison.OrdinalIgnoreCase)) return "NUM hold";
        if (bed.Specialty.Contains("Cardiology", StringComparison.OrdinalIgnoreCase)) return "Telemetry";
        return bed.Notes.Length > 26 ? bed.Notes[..26] + "…" : bed.Notes;
    }

    private void ToggleBay(string bayName)
    {
        var bay = Bays.First(x => x.BayName == bayName);
        bay.IsExpanded = !bay.IsExpanded;
    }

    private static void AllowDrop(DragEventArgs _) { }

    private void StartDragFromAllocation(PatientCard patient)
    {
        _dragMode = "allocation";
        _draggedAllocationPatient = patient;
        _draggedBedPatient = null;
    }

    private void StartDragFromBed(BayOperation bay, BedOperation bed)
    {
        _dragMode = "bed";
        _draggedBedPatient = (bay, bed);
        _draggedAllocationPatient = null;

        if (!_isAllocationPanelOpen)
        {
            _isAllocationPanelOpen = true;
        }
    }

    private void DropPatientToBed(BayOperation bay, BedOperation bed)
    {
        if (_dragMode != "allocation" || _draggedAllocationPatient is null || bed.Status != "Ready")
        {
            return;
        }

        bed.AssignFrom(_draggedAllocationPatient);

        foreach (var list in AllocationBySource.Values)
        {
            list.Remove(_draggedAllocationPatient);
        }

        RecalculateBay(bay);
        Toast($"Patient allocated to {bay.BayName} {bed.BedNumber}");

        _draggedAllocationPatient = null;
        _dragMode = "";
    }

    private void DropFromBedToTarget(string target)
    {
        if (_dragMode != "bed" || _draggedBedPatient is null)
        {
            return;
        }

        var (bay, bed) = _draggedBedPatient.Value;

        if (target == "IHT Returns")
        {
            AllocationBySource["IHT"].Add(new PatientCard(bed.PatientName, bed.AgeSex, bed.Specialty, "Now", "Standard", ""));
            bed.MarkCleaning("Moved to IHT Returns");
            RecalculateBay(bay);
            Toast("Patient moved to IHT Returns. Bed marked Cleaning.");
        }

        _draggedBedPatient = null;
        _dragMode = "";
    }

    private static void RecalculateBay(BayOperation bay)
    {
        bay.Occupied = bay.Beds.Count(x => x.Status == "Occupied");
        bay.Ready = bay.Beds.Count(x => x.Status == "Ready");
        bay.Cleaning = bay.Beds.Count(x => x.Status == "Cleaning");
        bay.Blocked = bay.Beds.Count(x => x.Status == "Blocked");
        bay.Maintenance = bay.Beds.Count(x => x.Status == "Maintenance");
    }

    private void Toast(string message)
    {
        _toastMessage = message;
    }

    private sealed class PatientCard(string name, string ageSex, string presentation, string eta, string needs, string priority)
    {
        public string Name { get; } = name;
        public string AgeSex { get; } = ageSex;
        public string Presentation { get; } = presentation;
        public string Eta { get; } = eta;
        public string Needs { get; } = needs;
        public string Priority { get; } = priority;
    }

    private sealed class BayOperation(string bayName, int totalBeds, int occupied, int ready, int cleaning, int blocked, int maintenance, string keyNotes, bool isExpanded, List<BedOperation> beds)
    {
        public string BayName { get; } = bayName;
        public int TotalBeds { get; } = totalBeds;
        public int Occupied { get; set; } = occupied;
        public int Ready { get; set; } = ready;
        public int Cleaning { get; set; } = cleaning;
        public int Blocked { get; set; } = blocked;
        public int Maintenance { get; set; } = maintenance;
        public string KeyNotes { get; } = keyNotes;
        public bool IsExpanded { get; set; } = isExpanded;
        public List<BedOperation> Beds { get; } = beds;
    }

    private sealed class BedOperation(string bedNumber, string patientName, string ageSex, string status, string statusClass, string specialty, string los, string notes)
    {
        public string BedNumber { get; } = bedNumber;
        public string PatientName { get; private set; } = string.IsNullOrWhiteSpace(patientName) ? "—" : patientName;
        public string AgeSex { get; private set; } = string.IsNullOrWhiteSpace(ageSex) ? "—" : ageSex;
        public string Status { get; private set; } = status;
        public string StatusClass { get; private set; } = statusClass;
        public string Specialty { get; private set; } = specialty;
        public string Los { get; private set; } = los;
        public string Notes { get; private set; } = notes;

        public void AssignFrom(PatientCard patient)
        {
            PatientName = patient.Name;
            AgeSex = patient.AgeSex;
            Status = "Occupied";
            StatusClass = "occupied";
            Specialty = patient.Presentation;
            Los = "0d";
            Notes = $"Allocated from panel ({patient.Eta})";
        }

        public void MarkCleaning(string note)
        {
            PatientName = "—";
            AgeSex = "—";
            Status = "Cleaning";
            StatusClass = "cleaning";
            Specialty = "-";
            Los = "-";
            Notes = note;
        }
    }
}
