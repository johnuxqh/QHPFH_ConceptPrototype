@page "/bed-management"
@using Microsoft.AspNetCore.Components.Web
@using MudBlazor

<section class="page-shell-card bed-mgmt-page ward-ops">
    @if (!string.IsNullOrWhiteSpace(_toastMessage)) { <div class="bm-toast">@_toastMessage</div> }

    <div class="bm-topbar">
        <div class="bm-filter"><label>Facility</label><button>QCH</button></div>
        <div class="bm-filter"><label>HHS</label><button>All</button></div>
        <div class="bm-filter"><label>Ward</label><button>8A Surgical</button></div>
        <input class="bm-search" placeholder="Search patients, beds, notes" />
        <button class="bm-ghost" @onclick="SetMapView">Map View</button>
        <button class="bm-ghost" @onclick="()=>_showHandover=true">Handover</button>
        <button class="bm-ghost" @onclick="()=>_showUtilities=true">More</button>
    </div>

    <section class="bm-capacity-banner red"><strong>HOSPITAL CAPACITY STATUS: RED</strong><span>High demand across ED and inpatient flow. Prioritise confirmed discharges before 11:00. Escalate blocked beds to NUM.</span></section>

    <section class="bm-summary-strip six">
        <article class="bm-summary-item"><p>Total Physical Beds</p><strong>48</strong></article>
        <article class="bm-summary-item"><p>Open Beds</p><strong class="tone-ready">8</strong></article>
        <article class="bm-summary-item"><p>Occupied Beds</p><strong class="tone-occupied">32</strong></article>
        <article class="bm-summary-item"><p>Pending Beds</p><strong>8</strong><small>Cleaning 4 • Maintenance 2 • Blocked 2</small></article>
        <article class="bm-summary-item"><p>Isolation / Specialist</p><strong>6</strong><small>4 Isolation • 2 Specialist</small></article>
        <article class="bm-summary-item clickable" @onclick="()=>_isAllocationPanelOpen=true"><p>Expected Admissions</p><strong>ED 4 • IHT 2</strong><small>OPD 1 • Other 0</small></article>
    </section>

    @if (SelectedView == "List View")
    {
        <section class="bm-ward-table-wrap">
            <table class="bm-ward-table"><thead><tr><th>Bed</th><th>Patient</th><th>Team</th><th>Allergies</th><th>Infection Control</th><th>Alerts</th><th>EDD</th><th>Discharge Progress</th><th>Requests / Results</th><th>EWS</th><th>Waiting For</th><th>Actions</th></tr></thead>
                <tbody>
                @foreach(var bed in BedRows.Take(10))
                {
                    <tr class="state-@bed.StatusClass" @ondragover="AllowDrop" @ondrop="(e)=>DropPatientToBed(bed)">
                        <td><strong>@bed.BedLabel</strong><div class="status-select"><select @bind="bed.Status"><option>Open / Ready</option><option>Occupied</option><option>Cleaning</option><option>Blocked</option><option>Maintenance</option><option>Isolation / Specialist</option></select></div></td>
                        <td>
                            @if (bed.HasPatient)
                            {
                                <div class="bm-bed-patient" draggable="true" @ondragstart="() => StartDragFromBed(bed)">@bed.PatientName</div>
                                <small>@bed.Demographics</small>
                            }
                            else { <strong>@(bed.Status is "Blocked" or "Maintenance" ? "BLOCKED" : "OPEN")</strong> }
                        </td>
                        <td>@bed.Team</td><td>@bed.Allergies</td><td>@bed.Infection</td><td>@bed.Alerts</td><td>@bed.Edd</td><td><div class="progress"><span style="width:@bed.DischargeProgress%"></span></div>@bed.DischargeProgress%</td><td>@bed.Requests</td><td>@bed.Ews</td><td>@bed.WaitingFor</td><td><button class="kebab">⋮</button></td>
                    </tr>
                }
                </tbody>
            </table>
            <footer>Showing 1–10 of 48 beds</footer>
        </section>
    }

    @if (_isAllocationPanelOpen){@Slideout("Allocation Board")}
    @if (_showHandover){@HandoverSlideout()}
    @if (_showUtilities){@UtilitiesSlideout()}
</section>

@code {
    private string SelectedView { get; set; } = "List View";
    private bool _isAllocationPanelOpen;
    private bool _showHandover;
    private bool _showUtilities;
    private string? _toastMessage;
    private string _dragMode = "";
    private IncomingCard? _draggedIncoming;
    private BedRow? _draggedBed;
    private string _activeTab = "ED";

    private readonly Dictionary<string,List<IncomingCard>> IncomingByTab = new(){["ED"]= [new("ED001 | 45m","JAMES, Peter","Appendicitis","ETA 30m | Gen Surg","High"),new("ED002 | 68f","MARTIN, Susan","Chest Pain","ETA 45m | Cardiology","Medium"),new("ED003 | 72m","ROBERTS, Alan","Abdominal Pain","ETA 60m | Gen Med","Medium"),new("ED004 | 55f","WALKER, Kim","COPD Exacerbation","ETA 90m | Respiratory","Low")],["IHT"]=[],["OPD"]=[],["Other"]=[]};
    private readonly List<string> MoveTargets=["IHT Returns Queue","Pending Transfer","Temporary Hold","Discharge Pending"];

    private readonly List<BedRow> BedRows = [
        new("Bed 1","Occupied","TAYLOR, Noah","MRN 8001234 | 45y | M","General Surgery","Penicillin","MRSA","Behavioural + Other Alert","22 May / 2 days",75,"Bloods / Resulted",2,"Discharge meds"),
        new("Bed 2","Occupied","NGUYEN, Scarlett","MRN 8002233 | 68y | F","Cardiology","None known allergy","No infection","Falls + Other Alert","25 May",25,"CXR Resulted",4,"Physio review"),
        new("Bed 3","Open / Ready","","","General Surgery","-","-","-","-",0,"-",0,"Available"),
        new("Bed 4","Cleaning","","","General Surgery","-","-","-","-",0,"-",0,"Awaiting cleaning"),
        new("Bed 5","Isolation / Specialist","PARKER, June","MRN 8003377 | 52y | F","General Surgery","Latex","Isolation","Infection control","24 May",40,"CT Pending",3,"NUM review"),
        new("Bed 6","Occupied","LEE, Aaron","MRN 8001112 | 37y | M","General Surgery","None","No infection","-","23 May",60,"Bloods Pending",2,"Discharge planning"),
        new("Bed 7","Open / Ready","","","General Surgery","-","-","-","-",0,"-",0,"Available"),
        new("Bed 8","Maintenance","","","-","-","-","-","-",0,"-",0,"Maintenance"),
        new("Bed 9","Blocked","","","-","-","-","-","-",0,"-",0,"NUM hold"),
        new("Bed 10","Occupied","WILLIAMS, Noah","MRN 8004455 | 41y | M","General Surgery","Penicillin","No infection","-","26 May",35,"ECG Resulted",1,"Awaiting review")
    ];

    private void SetMapView() => SelectedView = "Map View";
    private void AllowDrop(DragEventArgs _) { }
    private void StartDragFromIncoming(IncomingCard c){_dragMode="incoming";_draggedIncoming=c;_draggedBed=null;}
    private void StartDragFromBed(BedRow b){_dragMode="bed";_draggedBed=b;_draggedIncoming=null;_isAllocationPanelOpen=true;}
    private void DropPatientToBed(BedRow bed){if(_dragMode!="incoming"||_draggedIncoming is null||bed.Status!="Open / Ready")return;bed.Assign(_draggedIncoming);foreach(var l in IncomingByTab.Values)l.Remove(_draggedIncoming);_toastMessage=$"{bed.PatientName} allocated to {bed.BedLabel}.";_dragMode="";_draggedIncoming=null;}
    private void DropBedToTarget(string target){if(_dragMode!="bed"||_draggedBed is null)return;IncomingByTab["IHT"].Add(new IncomingCard("IHT-R",""+_draggedBed.PatientName,_draggedBed.Team,"From ward",target));var name=_draggedBed.PatientName;_draggedBed.MarkCleaning();_toastMessage=$"{name} moved to {target}. {_draggedBed.BedLabel} marked as Cleaning.";_draggedBed=null;_dragMode="";}

    private RenderFragment Slideout(string title) => @<>
        <div class="bm-slideout-backdrop" @onclick="()=>_isAllocationPanelOpen=false"></div>
        <aside class="bm-slideout wide"><header><h3>@title</h3><button @onclick="()=>_isAllocationPanelOpen=false">Close</button></header>
        <div class="bm-allocation-tabs">@foreach(var t in new[]{"ED 4","IHT 2","OPD 1","Other 0"}){var key=t.Split(' ')[0];<button class="@(_activeTab==key?"active":null)" @onclick="()=>_activeTab=key">@t</button>}</div>
        <div class="bm-cards">@foreach(var c in IncomingByTab[_activeTab]){<article class="bm-patient-card" draggable="true" @ondragstart="()=>StartDragFromIncoming(c)"><strong>@c.Code</strong><p>@c.Name</p><p>@c.Reason</p><p>@c.Meta</p><span class="bm-priority">@c.Priority</span></article>}</div>
        <h4>Drop zones</h4><div class="bm-targets">@foreach(var t in MoveTargets){<div class="bm-move-target" @ondragover="AllowDrop" @ondrop="(e)=>DropBedToTarget(t)">@t</div>}</div>
        <a class="bm-link" href="#">View full allocation centre</a></aside>
    </>;

    private RenderFragment HandoverSlideout() => @<><div class="bm-slideout-backdrop" @onclick="()=>_showHandover=false"></div><aside class="bm-slideout"><header><h3>Shift Handover</h3><button @onclick="()=>_showHandover=false">Close</button></header><h4>Priority Issues</h4><ul><li>Hospital capacity status: RED</li><li>Bed 8 maintenance pending</li><li>Bed 5 isolation patient requires review</li><li>Bed 2 recently moved to IHT, cleaning required</li></ul><h4>Patients to Watch</h4><ul><li>High EWS</li><li>Behavioural risk</li><li>Falls risk</li><li>Infection control</li></ul><h4>Discharge Focus</h4><ul><li>EDD today/tomorrow</li><li>Waiting for discharge meds</li><li>Waiting for physio review</li><li>Waiting for CT result</li></ul><h4>Admissions Expected</h4><p>ED 4 • IHT 2 • OPD 1</p><h4>Notes</h4><textarea placeholder="Add handover note"></textarea></aside></>;
    private RenderFragment UtilitiesSlideout() => @<><div class="bm-slideout-backdrop" @onclick="()=>_showUtilities=false"></div><aside class="bm-slideout"><header><h3>Ward Utilities</h3><button @onclick="()=>_showUtilities=false">Close</button></header><h4>Ward Actions</h4><ul><li>Print Ward Snapshot</li><li>Export Patient List</li><li>Open Shift Summary</li></ul><h4>Operational Management</h4><ul><li>Open / Close Surge Beds</li><li>Mark Bed or Area Out of Service</li><li>Bulk Update Bed Status</li><li>Cleaning Overview</li><li>Maintenance Overview</li></ul><h4>Communication</h4><ul><li>Send Ward Broadcast</li><li>Escalate Capacity Issue</li><li>Contact Bed Manager</li><li>View Hospital Alerts</li></ul><h4>Views & Layout</h4><ul><li>Compact View</li><li>Expanded Clinical View</li><li>Show / Hide Columns</li><li>Save My Layout</li></ul><h4>Administration</h4><ul><li>Ward Configuration</li><li>Specialist Bed Settings</li><li>Audit History</li><li>Archived Notes</li></ul></aside></>;

    private sealed class IncomingCard(string code,string name,string reason,string meta,string priority){public string Code=code;public string Name=name;public string Reason=reason;public string Meta=meta;public string Priority=priority;}
    private sealed class BedRow(string bedLabel,string status,string patientName,string demographics,string team,string allergies,string infection,string alerts,string edd,int dischargeProgress,string requests,int ews,string waitingFor){public string BedLabel=bedLabel;public string Status=status;public string PatientName=patientName;public string Demographics=demographics;public string Team=team;public string Allergies=allergies;public string Infection=infection;public string Alerts=alerts;public string Edd=edd;public int DischargeProgress=dischargeProgress;public string Requests=requests;public int Ews=ews;public string WaitingFor=waitingFor;public bool HasPatient=>!string.IsNullOrWhiteSpace(PatientName);public string StatusClass=>Status.ToLowerInvariant().Replace(" / ","-").Replace(" ","-"); public void Assign(IncomingCard c){PatientName=c.Name;Demographics="MRN pending";Team=c.Reason.Contains("Cardio")?"Cardiology":"General Surgery";Status="Occupied";WaitingFor="Admission";} public void MarkCleaning(){PatientName="";Demographics="";Status="Cleaning";WaitingFor="Awaiting cleaning";}}
}
