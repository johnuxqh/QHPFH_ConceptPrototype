    private static void AllowDrop(DragEventArgs _) { }

    private void HoverAction(string key)
    {
        _hoverAction = key;
    }

    private void StartDragFromIncoming(IncomingCard card)
    {
        _dragMode = "incoming";
        _draggedIncoming = card;
        _draggedBed = null;
        _draggedAction = null;
    }

    private void StartDragFromBed(BedRow bed)
    {
        _dragMode = "patient";
        _draggedBed = bed;
        _draggedIncoming = null;
        _draggedAction = null;
        _isAllocationPanelOpen = true;
    }

    private void StartDragBedForAction(BedRow bed)
    {
        _dragMode = "bed";
        _draggedBed = bed;
        _draggedIncoming = null;
        _draggedAction = null;
    }

    private void StartDragAction(string key)
    {
        _dragMode = "action";
        _draggedAction = key;
        _draggedIncoming = null;
        _draggedBed = null;
    }

    private void DropPatientToBed(BedRow bed)
    {
        if (_dragMode == "action" && !string.IsNullOrWhiteSpace(_draggedAction))
        {
            ApplyBedAction(bed, _draggedAction);
            _dragMode = string.Empty;
            _draggedAction = null;
            return;
        }

        if (_dragMode != "incoming" || _draggedIncoming is null)
        {
            return;
        }

        if (bed.Status != "Open / Ready")
        {
            Log($"{bed.BedLabel} cannot accept patient while {bed.Status}.");
            return;
        }

        bed.Assign(_draggedIncoming);

        foreach (var list in IncomingByTab.Values)
        {
            list.Remove(_draggedIncoming);
        }

        Log($"{bed.PatientName} allocated to {bed.BedLabel}");
        _draggedIncoming = null;
        _dragMode = string.Empty;
    }

    private void DropBedToAction(string key)
    {
        if (_dragMode != "bed" || _draggedBed is null) return;
        ApplyBedAction(_draggedBed, key);
        _draggedBed = null;
        _dragMode = "";
        _hoverAction = null;
    }

    private void ApplyBedAction(BedRow bed, string key)
    {
        if ((key == "ready" || key == "cleaning") && bed.Status == "Occupied")
        {
            Log("Patient must be transferred/discharged first.");
            return;
        }

        if (key == "ready") { bed.Status = "Open / Ready"; bed.WaitingFor = "Available"; }
        else if (key == "cleaning") { bed.Status = "Cleaning"; bed.WaitingFor = "Awaiting cleaning"; }
        else if (key == "block") { bed.Status = "Blocked"; bed.WaitingFor = "NUM hold"; }
        else if (key == "maintenance") { bed.Status = "Maintenance"; bed.WaitingFor = "Maintenance review"; }
        else if (key == "isolation") { bed.Status = "Isolation / Specialist"; bed.WaitingFor = "Isolation review"; }
        else if (key == "note") { bed.WaitingFor = "Operational note added"; }
            Log($"{bed.BedLabel} is occupied. Move/discharge patient first.");
            return;
        }

        if (key == "ready")
        {
            bed.Status = "Open / Ready";
        }
        else if (key == "cleaning")
        {
            bed.Status = "Cleaning";
        }
        else if (key == "block")
        {
            bed.Status = "Blocked";
        }
        else if (key == "maintenance")
        {
            bed.Status = "Maintenance";
        }
        else if (key == "isolation")
        {
            bed.Status = "Isolation / Specialist";
        }

        if (key == "note")
        {
            bed.WaitingFor = "Operational note added";
        }

        Log($"{bed.BedLabel} {ActionText(key)}");
    }

    private string ActionText(string key) => key switch { "ready" => "marked Ready", "cleaning" => "marked Cleaning", "block" => "blocked", "maintenance" => "maintenance requested", "isolation" => "marked Isolation", _ => "note added" };

    private void DropBedToTarget(string target)
    {
        if (_dragMode != "patient" || _draggedBed is null) return;
        IncomingByTab["IHT"].Add(new IncomingCard("IHT-R", _draggedBed.PatientName, _draggedBed.Team, "From ward", target));
        var bedLabel = _draggedBed.BedLabel;
        _draggedBed.MarkCleaning();
        if (target == "Discharge Pending") _draggedBed.WaitingFor = "Awaiting cleaning";
        Log($"{bedLabel} patient moved to {target}. {bedLabel} marked Cleaning.");
        _draggedBed = null;
        _dragMode = "";
    }

    private string StatusIcon(string status) => status switch { "Occupied" => Icons.Material.Outlined.Person, "Open / Ready" => Icons.Material.Outlined.CheckCircle, "Cleaning" => Icons.Material.Outlined.CleaningServices, "Blocked" => Icons.Material.Outlined.Lock, "Maintenance" => Icons.Material.Outlined.Handyman, "Isolation / Specialist" => Icons.Material.Outlined.Shield, _ => Icons.Material.Outlined.Bed };
    private void Log(string message) { Activity.Insert(0, $"{DateTime.Now:HH:mm} {message}"); _toastMessage = message; }

    private RenderFragment SimpleSlideout(string title, IEnumerable<string> lines) => @<>
        <div class="bm-slideout-backdrop" @onclick="() => { _showHandover = false; _showUtilities = false; }"></div>
        <aside class="bm-slideout"><header><h3>@title</h3><button @onclick="() => { _showHandover = false; _showUtilities = false; }">Close</button></header><ul>@foreach (var line in lines) { <li>@line</li> }</ul></aside>
    </>;

    private sealed class IncomingCard(string code, string name, string reason, string meta, string priority)
    {
        public string Code = code; public string Name = name; public string Reason = reason; public string Meta = meta; public string Priority = priority;
    }

    private sealed class BedRow(string bedLabel, string status, string patientName, string demographics, string team, string allergies, string infection, string alerts, string edd, int dischargeProgress, string requests, int ews, string waitingFor)
    {
        public string BedLabel = bedLabel; public string Status = status; public string PatientName = patientName; public string Demographics = demographics; public string Team = team; public string Allergies = allergies; public string Infection = infection; public string Alerts = alerts; public string Edd = edd; public int DischargeProgress = dischargeProgress; public string Requests = requests; public int Ews = ews; public string WaitingFor = waitingFor;
        public bool HasPatient => !string.IsNullOrWhiteSpace(PatientName);
        public string StatusClass => Status.ToLowerInvariant().Replace(" / ", "-").Replace(" ", "-");
        public void Assign(IncomingCard card) { PatientName = card.Name; Demographics = "MRN pending"; Team = card.Reason.Contains("Cardio") ? "Cardiology" : "General Surgery"; Status = "Occupied"; WaitingFor = "Admission"; }
        public void MarkCleaning() { PatientName = ""; Demographics = ""; Status = "Cleaning"; WaitingFor = "Awaiting cleaning"; }
    }
