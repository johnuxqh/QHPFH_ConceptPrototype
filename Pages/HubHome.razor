@page "/"

<section class="page-shell-card" aria-label="Main page content">
    <div class="page-filter-row" aria-label="Data filters">
        <div class="filter-group">
            <label>HSS:</label>
            <details class="filter-dropdown" @onfocusout="CloseDropdowns">
                <summary>@SelectedLabel(_selectedHhs)</summary>
                <div class="filter-menu">
                    <label><input type="checkbox" checked="@(!_selectedHhs.Any())" @onchange="() => ResetHhs()" /> Show all</label>
                    @foreach (var item in HhsOptions)
                    {
                        <label><input type="checkbox" checked="@_selectedHhs.Contains(item)" @onchange="() => ToggleHhs(item)" /> @item</label>
                    }
                </div>
            </details>
        </div>

        <div class="filter-group">
            <label>Facility:</label>
            <details class="filter-dropdown" @onfocusout="CloseDropdowns">
                <summary>@SelectedLabel(_selectedFacilities)</summary>
                <div class="filter-menu">
                    <label><input type="checkbox" checked="@(!_selectedFacilities.Any())" @onchange="() => ResetFacilities()" /> Show all</label>
                    @foreach (var item in FacilityOptions)
                    {
                        <label><input type="checkbox" checked="@_selectedFacilities.Contains(item)" @onchange="() => ToggleFacility(item)" /> @item</label>
                    }
                </div>
            </details>
        </div>

        <div class="filter-group">
            <label>Ward:</label>
            <details class="filter-dropdown" @onfocusout="CloseDropdowns">
                <summary>@WardLabel</summary>
                <div class="filter-menu">
                    @if (!CanViewWards)
                    {
                        <div class="filter-hint">Select facilities to enable wards.</div>
                    }
                    else
                    {
                        <label><input type="checkbox" checked="@(!_selectedWards.Any())" @onchange="() => ResetWards()" /> Show all</label>
                        @foreach (var item in WardOptions)
                        {
                            <label><input type="checkbox" checked="@_selectedWards.Contains(item)" @onchange="() => ToggleWard(item)" /> @item</label>
                        }
                    }
                </div>
            </details>
        </div>
    </div>
</section>

@code {
    private readonly List<string> HhsOptions = ["Metro North", "Metro South", "Gold Coast", "Sunshine Coast"];

    private readonly Dictionary<string, List<string>> FacilityByHhs = new()
    {
        ["Metro North"] = ["RBWH", "Redcliffe", "Caboolture"],
        ["Metro South"] = ["PAH", "QEII", "Logan"],
        ["Gold Coast"] = ["GCUH", "Robina"],
        ["Sunshine Coast"] = ["SCUH", "Nambour"]
    };

    private readonly Dictionary<string, List<string>> WardByFacility = new()
    {
        ["RBWH"] = ["Ward 5A", "Ward 7B"], ["Redcliffe"] = ["Ward R1"], ["Caboolture"] = ["Ward C1"],
        ["PAH"] = ["Ward P1", "Ward P2"], ["QEII"] = ["Ward Q1"], ["Logan"] = ["Ward L1"],
        ["GCUH"] = ["Ward G1"], ["Robina"] = ["Ward Rb1"], ["SCUH"] = ["Ward S1"], ["Nambour"] = ["Ward N1"]
    };

    private readonly HashSet<string> _selectedHhs = [];
    private readonly HashSet<string> _selectedFacilities = [];
    private readonly HashSet<string> _selectedWards = [];

    private List<string> FacilityOptions => (_selectedHhs.Any() ? _selectedHhs.ToList() : HhsOptions);
        .SelectMany(h => FacilityByHhs[h])
        .Distinct()
        .ToList();

    private bool CanViewWards => _selectedFacilities.Any();

    private List<string> WardOptions => _selectedFacilities
        .SelectMany(f => WardByFacility.TryGetValue(f, out var wards) ? wards : [])
        .Distinct()
        .ToList();

    private string WardLabel => !CanViewWards ? "All" : SelectedLabel(_selectedWards);

    private static string SelectedLabel(HashSet<string> selected) => selected.Count == 0 ? "All" : selected.Count == 1 ? selected.First() : $"{selected.Count} selected";

    private void ToggleHhs(string item)
    {
        ToggleSet(_selectedHhs, item);
        _selectedFacilities.RemoveWhere(f => !FacilityOptions.Contains(f));
        _selectedWards.Clear();
    }

    private void ToggleFacility(string item)
    {
        ToggleSet(_selectedFacilities, item);
        _selectedWards.RemoveWhere(w => !WardOptions.Contains(w));
    }

    private void ToggleWard(string item) => ToggleSet(_selectedWards, item);

    private static void ToggleSet(HashSet<string> set, string item)
    {
        if (!set.Add(item)) set.Remove(item);
    }

    private void ResetHhs() { _selectedHhs.Clear(); _selectedFacilities.Clear(); _selectedWards.Clear(); }
    private void ResetFacilities() { _selectedFacilities.Clear(); _selectedWards.Clear(); }
    private void ResetWards() => _selectedWards.Clear();

    private void CloseDropdowns(FocusEventArgs _) { }
}
