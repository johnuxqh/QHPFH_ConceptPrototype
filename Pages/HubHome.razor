@using QHPFH_ConceptPrototype.Data
@using QHPFH_ConceptPrototype.Models
@inject QHPFH_ConceptPrototype.Components.Shells.NavigationState NavigationState
@page "/"
@implements IDisposable

@if (IsBedManagementPage)
{
    <section class="page-shell-card bed-management-page" aria-label="Bed management content" @onclick="CloseAllDropdowns">
        <div class="page-filter-row" aria-label="Bed management filters" @onclick:stopPropagation="true">
            <div class="filter-group">
                <label>HHS:</label>
                <button type="button"
                        class="filter-trigger @(_isHhsOpen ? "open" : null)"
                        @onclick="ToggleHhsDropdown">
                    @SelectedLabel(_selectedHhs)
                </button>

                @if (_isHhsOpen)
                {
                    <div class="filter-menu">
                        <label>
                            <input type="checkbox" checked="@(!_selectedHhs.Any())" @onchange="ResetHhs" />
                            All
                        </label>

                        @foreach (var item in HhsOptions.Where(x => x != All))
                        {
                            <label>
                                <input type="checkbox" checked="@_selectedHhs.Contains(item)" @onchange="@(() => ToggleHhs(item))" />
                                @item
                            </label>
                        }
                    </div>
                }
            </div>

            <div class="filter-group">
                <label>Facility:</label>
                <button type="button"
                        class="filter-trigger @(_isFacilityOpen ? "open" : null)"
                        @onclick="ToggleFacilityDropdown">
                    @SelectedLabel(_selectedFacilities)
                </button>

                @if (_isFacilityOpen)
                {
                    <div class="filter-menu">
                        <label>
                            <input type="checkbox" checked="@(!_selectedFacilities.Any())" @onchange="ResetFacilities" />
                            All
                        </label>

                        @foreach (var item in FilteredFacilityOptions.Where(x => x != All))
                        {
                            <label>
                                <input type="checkbox" checked="@_selectedFacilities.Contains(item)" @onchange="@(() => ToggleFacility(item))" />
                                @item
                            </label>
                        }
                    </div>
                }
            </div>

            <div class="filter-group">
                <label>Ward:</label>
                <button type="button"
                        class="filter-trigger @(_isWardOpen ? "open" : null)"
                        @onclick="ToggleWardDropdown">
                    @SelectedLabel(_selectedWards)
                </button>

                @if (_isWardOpen)
                {
                    @if (!_selectedFacilities.Any())
                    {
                        <div class="filter-menu">
                            <span class="filter-empty">Select one or more facilities to load wards</span>
                        </div>
                    }
                    else
                    {
                        <div class="filter-menu">
                            <label>
                                <input type="checkbox" checked="@(!_selectedWards.Any())" @onchange="ResetWards" />
                                All
                            </label>

                            @foreach (var item in FilteredWardOptions.Where(x => x != All))
                            {
                                <label>
                                    <input type="checkbox" checked="@_selectedWards.Contains(item)" @onchange="@(() => ToggleWard(item))" />
                                    @item
                                </label>
                            }
                        </div>
                    }
                }
            </div>
        </div>

        <section class="situational-panel">
            @foreach (var metric in SituationalPanelItems)
            {
                <article class="situational-card">
                    <div class="situational-head">
                        <p>@metric.Title</p>
                        <MudIcon Icon="@metric.Icon"
                                 Size="Size.Medium"
                                 Class="@($"situational-icon {metric.AccentClass}")" />
                    </div>

                    <h3 class="@metric.AccentClass">@metric.Value</h3>

                    <div class="situational-foot">
                        <span>@metric.Subtitle</span>
                        @if (!string.IsNullOrWhiteSpace(metric.TrailingLabel))
                        {
                            <span class="trail">@metric.TrailingLabel</span>
                        }
                    </div>

                    @if (!string.IsNullOrWhiteSpace(metric.Delta24h))
                    {
                        <div class="situational-delta @metric.DeltaClass">
                            <span>24h</span>
                            <strong>@metric.Delta24h</strong>
                        </div>
                    }
                </article>
            }
        </section>

        <section class="insights-panel">
            <h2>Actionable Insights</h2>

            <div class="insights-grid">
                @foreach (var insight in CalculatedInsights)
                {
                    <article class="insight-card @insight.Severity.ToLowerInvariant()">
                        <h3>@insight.Title</h3>
                        <p>@insight.Message</p>
                    </article>
                }
            </div>
        </section>

        <section class="main-scaffold">
            <div class="scaffold-header">
                <h2>Main Bed Management Workspace</h2>

                <div class="view-toggle" role="tablist" aria-label="View mode">
                    @foreach (var view in ViewModes)
                    {
                        <button type="button"
                                class="@(view == SelectedViewMode ? "active" : null)"
                                @onclick="() => SelectedViewMode = view">
                            @view
                        </button>
                    }
                </div>
            </div>

            <div class="scaffold-body">
                <p>@SelectedViewMode view scaffold ready. Detailed operational table/grid interactions will be enabled in the next implementation step.</p>
            </div>

            <footer>
                <button type="button" class="allocation-btn">Go to Allocations</button>
            </footer>
        </section>
    </section>
}
else
{
    <section class="page-shell-card"></section>
}

@code {
    private bool IsBedManagementPage =>
        NavigationState.ActivePrimaryKey == "bed" &&
        NavigationState.ActiveSubItem == "Bed Management";

    private bool _isHhsOpen;
    private bool _isFacilityOpen;
    private bool _isWardOpen;

    private static readonly string All = DemoReferenceData.All;

    private string SelectedViewMode { get; set; } = "List";

    private readonly List<string> ViewModes = ["List", "Grid", "Compact"];
    private readonly List<string> HhsOptions = [.. DemoReferenceData.HhsOptions];

    private readonly Dictionary<string, List<string>> FacilitiesByHhs =
        DemoReferenceData.FacilitiesByHhs.ToDictionary(x => x.Key, x => x.Value.ToList());

    private readonly List<WardRecord> Wards = DemoWardData.BuildWardRecords();

    private readonly HashSet<string> _selectedHhs = [];
    private readonly HashSet<string> _selectedFacilities = [];
    private readonly HashSet<string> _selectedWards = [];

    protected override void OnInitialized()
    {
        NavigationState.Changed += OnNavigationChanged;
    }

    private void OnNavigationChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        NavigationState.Changed -= OnNavigationChanged;
    }

    private List<string> FilteredFacilityOptions =>
    [
        All,
        .. (_selectedHhs.Any()
            ? _selectedHhs.SelectMany(hhs =>
                FacilitiesByHhs.TryGetValue(hhs, out var facilities)
                    ? facilities
                    : Enumerable.Empty<string>())
            : FacilitiesByHhs.Values.SelectMany(x => x))
            .Distinct()
            .OrderBy(x => x)
    ];

    private List<string> FilteredWardOptions =>
    [
        All,
        .. (_selectedFacilities.Any()
            ? Wards
                .Where(w => _selectedFacilities.Contains(w.Facility))
                .Select(w => w.WardName)
                .Distinct()
                .OrderBy(x => x)
            : Enumerable.Empty<string>())
    ];

    private IEnumerable<WardRecord> FilteredWards => Wards.Where(w =>
        (!_selectedHhs.Any() || _selectedHhs.Contains(w.Hhs)) &&
        (!_selectedFacilities.Any() || _selectedFacilities.Contains(w.Facility)) &&
        (!_selectedWards.Any() || _selectedWards.Contains(w.WardName)));

    private List<SituationalItem> SituationalPanelItems
    {
        get
        {
            var wards = FilteredWards.ToList();

            var totalPhysical = wards.Sum(x => x.PhysicalBeds);
            var totalOpen = wards.Sum(x => x.OpenBeds);
            var cleaningAwaiting = wards.Sum(x => x.CleaningAwaiting);
            var occupancy = wards.Any() ? wards.Average(x => x.OccupancyPercent) : 0;
            var capacityDelta = wards.Sum(x => x.CapacityDelta24h);
            var admissionsToday = wards.Sum(x => x.ElectiveAdmissionsToday + x.EdAddOnsToday + x.HithReturnsToday);
            var delayed = wards.Sum(x => x.DelayedDischargeCount);
            var admissionsPlan = wards.Sum(x => x.ElectiveAdmissionsToday);
            var openDelta = wards.Sum(x => x.CapacityDelta24h < 0 ? x.CapacityDelta24h : 0);
            var cleaningDelta = wards.Sum(x => x.CleaningAwaiting > 1 ? -1 : 0);
            var pressureDelta = wards.Count(x => x.PressureStatus is "High" or "Critical");

            return
            [
                new("PHYSICAL CAPACITY", totalPhysical.ToString("N0"), "Total Beds", Icons.Material.Outlined.KingBed, "blue"),
                new("OPEN OPERATIONAL BEDS", totalOpen.ToString("N0"), totalPhysical == 0 ? "0% of capacity" : $"{Math.Round((decimal)totalOpen / totalPhysical * 100, 0)}% of capacity", Icons.Material.Outlined.LocalHotel, "green", "red", $"▼ {Math.Abs(openDelta)}"),
                new("BEDS RETURNING", cleaningAwaiting.ToString("N0"), "Awaiting cleaning", Icons.Material.Outlined.CleaningServices, "orange", "red", $"▼ {Math.Abs(cleaningDelta)}"),
                new("OPERATIONAL PRESSURE", $"{Math.Round(occupancy, 0)}%", PressureBand(occupancy), Icons.Material.Outlined.Speed, "orange", "red", $"▲ {pressureDelta}%"),
                new("CAPACITY DELTA (24H)", $"{capacityDelta:+#;-#;0}", "6 OUT 11 IN", Icons.Material.Outlined.Equalizer, capacityDelta >= 0 ? "purple" : "red"),
                new("ADMISSIONS TODAY", admissionsToday.ToString("N0"), $"Planned: {admissionsPlan}", Icons.Material.Outlined.Groups, "teal"),
                new("DELAYED FLOW PATIENTS", delayed.ToString("N0"), wards.Any() ? $"{Math.Round((double)delayed / Math.Max(wards.Sum(x => x.OccupiedBeds), 1) * 100)}% of total patients" : "0% of total patients", Icons.Material.Outlined.Person, "red")
            ];
        }
    }

    private List<InsightItem> CalculatedInsights =>
        InsightEngine.BuildInsights(FilteredWards.ToList());

    private static string PressureBand(decimal occupancy) =>
        occupancy < 80 ? "Low" :
        occupancy < 90 ? "Medium" :
        occupancy < 95 ? "High" :
        "Critical";

    private void ToggleHhsDropdown() => ToggleDropdown("hhs");
    private void ToggleFacilityDropdown() => ToggleDropdown("facility");
    private void ToggleWardDropdown() => ToggleDropdown("ward");

    private void ToggleDropdown(string key)
    {
        _isHhsOpen = key == "hhs" && !_isHhsOpen;
        _isFacilityOpen = key == "facility" && !_isFacilityOpen;
        _isWardOpen = key == "ward" && !_isWardOpen;
    }

    private void CloseAllDropdowns()
    {
        _isHhsOpen = false;
        _isFacilityOpen = false;
        _isWardOpen = false;
    }

    private string SelectedLabel(HashSet<string> selected) =>
        selected.Count switch
        {
            0 => All,
            1 => selected.First(),
            _ => $"{selected.Count} selected"
        };

    private static void ToggleSet(HashSet<string> set, string value)
    {
        if (!set.Add(value))
        {
            set.Remove(value);
        }
    }

    private void ToggleHhs(string hhs)
    {
        ToggleSet(_selectedHhs, hhs);
        _selectedFacilities.RemoveWhere(f => !FilteredFacilityOptions.Contains(f));
        _selectedWards.Clear();
    }

    private void ToggleFacility(string facility)
    {
        ToggleSet(_selectedFacilities, facility);
        _selectedWards.RemoveWhere(w => !FilteredWardOptions.Contains(w));
    }

    private void ToggleWard(string ward)
    {
        ToggleSet(_selectedWards, ward);
    }

    private void ResetHhs()
    {
        _selectedHhs.Clear();
        _selectedFacilities.Clear();
        _selectedWards.Clear();
    }

    private void ResetFacilities()
    {
        _selectedFacilities.Clear();
        _selectedWards.Clear();
    }

    private void ResetWards()
    {
        _selectedWards.Clear();
    }

    private sealed record SituationalItem(
        string Title,
        string Value,
        string Subtitle,
        string Icon,
        string AccentClass,
        string DeltaClass = "",
        string Delta24h = "",
        string TrailingLabel = "");

    private sealed record InsightItem(string Title, string Message, string Severity);

    private static class InsightEngine
    {
        public static List<InsightItem> BuildInsights(List<WardRecord> wards)
        {
            var insights = new List<InsightItem>();

            var overCapacity = wards.Count(w => w.OccupancyPercent >= 100);
            if (overCapacity > 0)
            {
                insights.Add(new($"{overCapacity} wards are over capacity", "Immediate demand management and patient flow escalation advised.", "Critical"));
            }

            var cleaningBacklog = wards.Where(w => w.CleaningAwaiting >= 3).ToList();
            if (cleaningBacklog.Any())
            {
                insights.Add(new("Cleaning backlog contributing to pressure", $"{cleaningBacklog.Sum(x => x.CleaningAwaiting)} beds are awaiting cleaning across pressured wards.", "High"));
            }

            var staffingImpact = wards.Where(w => w.BedReductionReason == "Insufficient staffing").Sum(x => x.NonOperationalBeds);
            if (staffingImpact > 0)
            {
                insights.Add(new("Staffing impact reducing operational beds", $"{staffingImpact} beds unavailable due to staffing constraints.", "High"));
            }

            var delayed = wards.Where(w => w.PressureStatus is "High" or "Critical").Sum(x => x.DelayedDischargeCount);
            if (delayed > 0)
            {
                insights.Add(new("Delayed discharge concentration in critical wards", $"{delayed} delayed discharges recorded in high-pressure wards.", "Medium"));
            }

            var electiveSurge = wards.Sum(w => w.ElectiveAdmissionsToday) > wards.Sum(w => w.ActualDischargesToday);
            if (electiveSurge)
            {
                insights.Add(new("Elective surge expected tomorrow", "Planned elective demand is outpacing current discharge throughput.", "Medium"));
            }

            if (!insights.Any())
            {
                insights.Add(new("Capacity profile stable", "No immediate pressure flags in the current filter context.", "Low"));
            }

            return insights;
        }
    }
}
