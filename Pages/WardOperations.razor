@page "/ward-operations"
@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@using QHPFH_ConceptPrototype.Data

<section class="page-shell-card bed-mgmt-page ward-ops">
    @if (!string.IsNullOrWhiteSpace(_toastMessage))
    {
        <div class="bm-toast">@_toastMessage</div>
    }

    <header>
        <h2>Ward Operations</h2>
    </header>

    <div class="bm-topbar">
        <div class="bm-filter"><label>Facility</label><button type="button">QCH</button></div>
        <div class="bm-filter"><label>HHS</label><button type="button">All</button></div>
        <div class="bm-filter"><label>Ward</label><button type="button">8A Surgical</button></div>
        <input class="bm-search" placeholder="Search patients, beds, notes" />
        @foreach (var view in ViewModes)
        {
            <button type="button" class="bm-ghost view @(SelectedView == view ? "active" : null)" @onclick="() => SelectedView = view">@view</button>
        }
        <button type="button" class="bm-ghost" @onclick="() => _showHandover = true">Handover</button>
        <button type="button" class="bm-ghost" @onclick="() => _showUtilities = true">More</button>
    </div>


    @if (_showHandover)
    {
        <section class="bm-inline-sheet" role="status" aria-live="polite">
            <strong>Handover</strong>
            <span>Fictional demo handover workspace coming soon.</span>
            <button type="button" class="bm-ghost" @onclick="() => _showHandover = false">Close</button>
        </section>
    }

    @if (_showUtilities)
    {
        <section class="bm-inline-sheet" role="status" aria-live="polite">
            <strong>More Utilities</strong>
            <span>Fictional demo utility workspace coming soon.</span>
            <button type="button" class="bm-ghost" @onclick="() => _showUtilities = false">Close</button>
        </section>
    }

    <section class="bm-capacity-banner red">
        <strong>HOSPITAL CAPACITY STATUS: RED</strong>
        <span>High demand across ED and inpatient flow. Prioritise confirmed discharges before 11:00. Escalate blocked beds to NUM.</span>
    </section>

    <section class="bm-summary-strip six">
        <article class="bm-summary-item"><p>Total Physical Beds</p><strong>48</strong></article>
        <article class="bm-summary-item"><p>Open Beds</p><strong class="tone-ready">8</strong></article>
        <article class="bm-summary-item"><p>Occupied Beds</p><strong class="tone-occupied">32</strong></article>
        <article class="bm-summary-item"><p>Pending Beds</p><strong>8</strong><small>Cleaning 4 • Maintenance 2 • Blocked 2</small></article>
        <article class="bm-summary-item"><p>Isolation / Specialist Beds</p><strong>6</strong><small>4 Isolation • 2 Specialist</small></article>
        <article class="bm-summary-item"><p>Expected Admissions</p><strong>ED 4 • IHT 2</strong><small>OPD 1 • Other 0</small></article>
    </section>

    <div class="bm-main-grid">
        <section class="bm-list-panel">
            @if (SelectedView == "List View")
            {
                <section class="bm-ward-table-wrap">
                    <table class="bm-ward-table">
                        <thead><tr><th>Bed</th><th>Status</th><th>Patient</th><th>Team</th><th>Allergies</th><th>Infection Control</th><th>Alerts</th><th>EDD</th><th>Discharge Progress</th><th>Requests / Results</th><th>EWS</th><th>Waiting For</th><th>Actions</th></tr></thead>
                        <tbody>
                            @foreach (var bed in BedRows.Take(10))
                            {
                                <tr class="state-@bed.StatusClass" draggable="true" @ondragstart="() => StartDragBedForAction(bed)" @ondragover="AllowDrop" @ondragover:preventDefault="true" @ondrop="() => DropPatientToBed(bed)">
                                    <td><strong>@bed.BedLabel</strong></td>
                                    <td><div class="bm-status-pill"><MudIcon Icon="@StatusIcon(bed.Status)" Size="Size.Small" /> @bed.Status</div></td>
                                    <td>
                                        @if (bed.HasPatient)
                                        {
                                            <div class="bm-bed-patient" draggable="true" @ondragstart="() => StartDragFromBed(bed)">@bed.PatientName</div><small>@bed.Demographics</small>
                                        }
                                        else
                                        {
                                            <strong>—</strong>
                                        }
                                    </td>
                                    <td>@bed.Team</td><td>@bed.Allergies</td><td>@bed.Infection</td><td>@bed.Alerts</td><td>@bed.Edd</td>
                                    <td><div class="progress"><span style="@($"width:{bed.DischargeProgress}%")"></span></div>@bed.DischargeProgress%</td>
                                    <td>@bed.Requests</td><td>@bed.Ews</td><td>@bed.WaitingFor</td>
                                    <td>
                                        <div class="bm-inline-actions">
                                            @foreach (var action in ActionDefs)
                                            {
                                                <button type="button" title="@action.Label" @onclick="() => ApplyBedAction(bed, action.Key)"><MudIcon Icon="@action.Icon" Size="Size.Small" /></button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <footer>Showing 1–10 of 48 beds</footer>
                </section>
            }
            else if (SelectedView == "Grid View")
            {
                <div class="bm-grid-view">
                    @foreach (var bay in BayLayouts)
                    {
                        <article class="bm-bay-card">
                            <header><h4>@bay.Key</h4><span>@bay.Value.Count beds</span></header>
                            <div class="bm-bed-tiles bm-cols-@Math.Min(4, bay.Value.Count)">
                                @foreach (var bed in bay.Value)
                                {
                                    <article class="bm-bed-tile state-@bed.StatusClass" draggable="true" @ondragstart="() => StartDragBedForAction(bed)" @ondragover="AllowDrop" @ondragover:preventDefault="true" @ondrop="() => DropPatientToBed(bed)">
                                        <div class="bm-bed-tile-head"><strong>@bed.BedLabel</strong><span class="bm-status-pill"><MudIcon Icon="@StatusIcon(bed.Status)" Size="Size.Small" /></span></div>
                                        <div>@(bed.HasPatient ? bed.PatientName : "—")</div>
                                        <small class="bm-bed-note-short">@bed.WaitingFor</small>
                                        <div class="bm-inline-actions">
                                            @foreach (var action in ActionDefs)
                                            {
                                                <button type="button" title="@action.Label" @onclick="() => ApplyBedAction(bed, action.Key)"><MudIcon Icon="@action.Icon" Size="Size.Small" /></button>
                                            }
                                        </div>
                                    </article>
                                }
                            </div>
                        </article>
                    }
                </div>
            }
            else
            {
                <div class="bm-map-layout">
                    <div class="bm-zone bm-corridor">Ward corridor / circulation</div>
                    <div class="bm-zone bm-staff">Staff Station</div><div class="bm-zone bm-treatment">Treatment Room</div>
                    <div class="bm-zone bm-clean">Clean Utility</div><div class="bm-zone bm-soiled">Soiled Utility</div><div class="bm-zone bm-store">Store Room</div>
                    @foreach (var bay in BayLayouts)
                    {
                        <section class="bm-map-bay bm-map-bay-@bay.Key.ToLowerInvariant().Replace(" ", string.Empty)">
                            <header>@bay.Key</header>
                            <div class="bm-map-beds bm-cols-@Math.Min(4, bay.Value.Count)">
                                @foreach (var bed in bay.Value)
                                {
                                    <article class="bm-map-bed state-@bed.StatusClass" draggable="true" @ondragstart="() => StartDragBedForAction(bed)" @ondragover="AllowDrop" @ondragover:preventDefault="true" @ondrop="() => DropPatientToBed(bed)">
                                        <div class="bm-map-bed-top"><strong>@bed.BedLabel</strong><MudIcon Icon="@StatusIcon(bed.Status)" Size="Size.Small" /></div>
                                        <small>@(bed.HasPatient ? bed.PatientName : bed.Status)</small>
                                    </article>
                                }
                            </div>
                        </section>
                    }
                </div>
            }
        </section>

        <aside class="bm-right-panel">
            <article>
                <h4>Incoming</h4>
                <div class="bm-allocation-tabs">
                    @foreach (var tab in IncomingTabs)
                    {
                        <button type="button" class="@(IncomingTab == tab ? "active" : null)" @onclick="() => IncomingTab = tab">@tab (@IncomingByTab[tab].Count)</button>
                    }
                </div>
                <div class="bm-cards">
                    @foreach (var card in IncomingByTab[IncomingTab].Take(4))
                    {
                        <article class="bm-patient-card" draggable="true" @ondragstart="() => StartDragFromIncoming(card)"><strong>@card.Code</strong><p>@card.Name</p><p>@card.Reason</p><p>@card.Meta</p><span class="bm-priority">@card.Priority</span></article>
                    }
                </div>
            </article>

            <article><h4>Quick Actions</h4><div class="bm-actions">@foreach (var action in ActionDefs){<button type="button" class="qa-drop @(_hoverAction == action.Key ? "hover" : null)" @ondragover="() => HoverAction(action.Key)" @ondragover:preventDefault="true" @ondragleave="() => _hoverAction = null" @ondrop="() => DropBedToAction(action.Key)"><MudIcon Icon="@action.Icon" Size="Size.Small" /> @action.Label</button>}</div></article>
            <article><h4>Drop Zones</h4><div class="bm-targets">@foreach (var target in MoveTargets){<div class="bm-move-target" @ondragover="AllowDrop" @ondragover:preventDefault="true" @ondrop="() => DropBedToTarget(target)">@target</div>}</div></article>
            <article><h4>Recent Activity</h4><ul class="bm-activity">@foreach (var item in Activity.Take(8)){<li>@item</li>}</ul></article>
        </aside>
    </div>
</section>

@code {
    private string SelectedView { get; set; } = "List View";
    private string IncomingTab { get; set; } = "ED";
    private bool _showUtilities;
    private bool _showHandover;
    private string? _toastMessage;
    private string? _hoverAction;
    private string _dragMode = string.Empty;
    private IncomingCard? _draggedIncoming;
    private BedRow? _draggedBed;
    private static readonly string[] ViewModes = { "Map View", "List View", "Grid View" };
    private static readonly string[] IncomingTabs = { "ED", "IHT", "OPD", "Other" };
    private readonly List<string> Activity = new() { "12:20 Bed 3 marked Cleaning", "12:25 Bed 3 marked Ready", "12:26 Bed 4 blocked due to adjacent behaviour risk", "12:27 Maintenance requested for Bed 8" };
    private readonly (string Key, string Label, string Icon)[] ActionDefs = { ("ready", "Mark Ready", Icons.Material.Outlined.CheckCircle), ("cleaning", "Mark Cleaning", Icons.Material.Outlined.CleaningServices), ("block", "Block Bed", Icons.Material.Outlined.Lock), ("maintenance", "Request Maintenance", Icons.Material.Outlined.Handyman), ("isolation", "Isolation", Icons.Material.Outlined.Shield), ("note", "Add Operational Note", Icons.Material.Outlined.StickyNote2) };
    private readonly Dictionary<string, List<IncomingCard>> IncomingByTab = new() { ["ED"] = new(), ["IHT"] = new(), ["OPD"] = new(), ["Other"] = new() };
    private readonly List<string> MoveTargets = new() { "IHT Returns Queue", "Pending Transfer", "Temporary Hold", "Discharge Pending" };
    private List<BedRow> BedRows = new();
    private Dictionary<string, List<BedRow>> BayLayouts => new() { ["Bay 1"] = BedRows.Take(2).ToList(), ["Bay 2"] = BedRows.Skip(2).Take(3).ToList(), ["Bay 3"] = BedRows.Skip(5).Take(4).ToList(), ["Bay 4"] = BedRows.Skip(9).Take(3).ToList(), ["Bay 5"] = BedRows.Skip(12).Take(2).ToList(), ["Bay 6"] = BedRows.Skip(14).Take(2).ToList(), ["Bay 7"] = BedRows.Skip(16).Take(3).ToList(), ["Bay 8"] = BedRows.Skip(19).Take(3).ToList(), ["Bay 9"] = BedRows.Skip(22).Take(4).ToList(), ["Bay 10"] = BedRows.Skip(26).Take(3).ToList() };

    protected override void OnInitialized()
    {
        var feed = DemoHubData.BuildPatientAdmissions();
        BedRows = Enumerable.Range(1, 48).Select(n => CreateBed(n, feed)).ToList();
        IncomingByTab["ED"] = feed.Take(4).Select((p, i) => new IncomingCard($"ED{i + 1:000}", $"{p.LastName.ToUpperInvariant()}, {p.FirstName}", "Emergency admission", $"{DateTime.Now.AddMinutes(20 + i * 10):HH:mm}", i == 0 ? "High" : "Medium")).ToList();
        IncomingByTab["IHT"] = feed.Skip(20).Take(2).Select((p, i) => new IncomingCard($"IHT{i + 1:000}", $"{p.LastName.ToUpperInvariant()}, {p.FirstName}", "Inter-hospital transfer", $"{DateTime.Now.AddMinutes(35 + i * 10):HH:mm}", "Medium")).ToList();
        IncomingByTab["OPD"] = feed.Skip(40).Take(1).Select((p, i) => new IncomingCard($"OPD{i + 1:000}", $"{p.LastName.ToUpperInvariant()}, {p.FirstName}", "Post procedure", $"{DateTime.Now.AddMinutes(55):HH:mm}", "Low")).ToList();
    }

    private static BedRow CreateBed(int n, IReadOnlyList<Models.PatientAdmission> feed)
    {
        if (n == 1) return new($"Bed {n}", "Occupied", "WAYNE, Bruce", "MRN DEMO001 | 45y | M", "General Surgery", "Penicillin", "No infection", "Behavioural alert", "22 May", 75, "Bloods resulted", 2, "Discharge meds");
        if (n == 2) return new($"Bed {n}", "Occupied", "KENT, Clark", "MRN DEMO002 | 68y | M", "Cardiology", "NKA", "No infection", "Falls", "25 May", 25, "CXR resulted", 4, "Physio review");
        if (n == 5) return new($"Bed {n}", "Isolation / Specialist", "PRINCE, Diana", "MRN DEMO005 | 52y | F", "General Surgery", "Latex", "Isolation", "Non-isolation diagnosis, review fit", "24 May", 40, "CT pending", 3, "NUM review");
        if (n == 8) return new($"Bed {n}", "Maintenance", "", "", "-", "-", "-", "Unavailable", "-", 0, "-", 0, "Maintenance review");
        if (n == 9) return new($"Bed {n}", "Blocked", "", "", "-", "-", "-", "Adjacent behaviour risk", "-", 0, "-", 0, "NUM hold");
        var status = n % 7 == 0 ? "Open / Ready" : n % 6 == 0 ? "Cleaning" : "Occupied";
        var patient = feed[(n * 3) % feed.Count];
        var patientName = status == "Occupied" ? $"{patient.LastName.ToUpperInvariant()}, {patient.FirstName}" : string.Empty;
        var demographics = status == "Occupied" ? $"MRN DEMO{n:000} | {patient.Age}y | {patient.Gender}" : string.Empty;
        return new($"Bed {n}", status, patientName, demographics, "General Surgery", status == "Occupied" ? "None" : "-", status == "Occupied" ? "No infection" : "-", "-", "26 May", status == "Occupied" ? 30 : 0, status == "Occupied" ? "Results pending" : "-", status == "Occupied" ? 2 : 0, status == "Open / Ready" ? "Available" : status == "Cleaning" ? "Awaiting cleaning" : "Clinical review");
    }

    private static void AllowDrop(DragEventArgs _) { }
    private void HoverAction(string key) => _hoverAction = key;
    private void StartDragFromIncoming(IncomingCard card){_dragMode = "incoming"; _draggedIncoming = card; _draggedBed = null;}
    private void StartDragFromBed(BedRow bed){_dragMode = "patient"; _draggedBed = bed; _draggedIncoming = null;}
    private void StartDragBedForAction(BedRow bed){_dragMode = "bed"; _draggedBed = bed; _draggedIncoming = null;}

    private void DropPatientToBed(BedRow bed)
    {
        if (_dragMode != "incoming" || _draggedIncoming is null) return;
        if (bed.Status is "Maintenance" or "Blocked" or "Cleaning" || bed.Status != "Open / Ready") { Log($"Invalid drop: {bed.BedLabel} cannot accept patient while {bed.Status}."); return; }
        bed.Assign(_draggedIncoming); foreach (var list in IncomingByTab.Values) list.Remove(_draggedIncoming);
        Log($"{bed.PatientName} allocated to {bed.BedLabel}"); _draggedIncoming = null; _dragMode = string.Empty;
    }

    private void DropBedToAction(string key){if (_dragMode != "bed" || _draggedBed is null) return; ApplyBedAction(_draggedBed, key); _draggedBed = null; _dragMode = string.Empty; _hoverAction = null;}

    private void ApplyBedAction(BedRow bed, string key)
    {
        if ((key == "ready" || key == "cleaning") && bed.Status == "Occupied") { Log("Invalid action: Occupied beds must be moved/discharged first."); return; }
        if (key == "ready") { bed.Status = "Open / Ready"; bed.WaitingFor = "Available"; }
        else if (key == "cleaning") { bed.Status = "Cleaning"; bed.WaitingFor = "Awaiting cleaning"; }
        else if (key == "block") { bed.Status = "Blocked"; bed.WaitingFor = "NUM hold"; bed.Alerts = "Adjacent behaviour risk"; }
        else if (key == "maintenance") { bed.Status = "Maintenance"; bed.WaitingFor = "Maintenance review"; }
        else if (key == "isolation") { bed.Status = "Isolation / Specialist"; bed.WaitingFor = "Isolation review"; }
        else if (key == "note") { bed.WaitingFor = "Operational note added"; }
        Log($"{bed.BedLabel} {ActionText(key)}");
    }

    private void DropBedToTarget(string target)
    {
        if (_dragMode != "patient" || _draggedBed is null || !_draggedBed.HasPatient) return;
        IncomingByTab["IHT"].Add(new IncomingCard("IHT-R", _draggedBed.PatientName, _draggedBed.Team, "From ward", target));
        var bedLabel = _draggedBed.BedLabel; _draggedBed.MarkCleaning(); Log($"{bedLabel} patient moved to {target}. {bedLabel} marked Cleaning."); _draggedBed = null; _dragMode = string.Empty;
    }

    private static string StatusIcon(string status) => status switch { "Occupied" => Icons.Material.Outlined.Person, "Open / Ready" => Icons.Material.Outlined.CheckCircle, "Cleaning" => Icons.Material.Outlined.CleaningServices, "Blocked" => Icons.Material.Outlined.Lock, "Maintenance" => Icons.Material.Outlined.Handyman, "Isolation / Specialist" => Icons.Material.Outlined.Shield, _ => Icons.Material.Outlined.Bed };
    private static string ActionText(string key) => key switch { "ready" => "marked Ready", "cleaning" => "marked Cleaning", "block" => "blocked", "maintenance" => "maintenance requested", "isolation" => "marked Isolation", _ => "note added" };
    private void Log(string message){Activity.Insert(0, $"{DateTime.Now:HH:mm} {message}"); _toastMessage = message;}

    private sealed class IncomingCard { public IncomingCard(string code, string name, string reason, string meta, string priority){Code = code;Name = name;Reason = reason;Meta = meta;Priority = priority;} public string Code { get; } public string Name { get; } public string Reason { get; } public string Meta { get; } public string Priority { get; } }
    private sealed class BedRow
    {
        public BedRow(string bedLabel, string status, string patientName, string demographics, string team, string allergies, string infection, string alerts, string edd, int dischargeProgress, string requests, int ews, string waitingFor){BedLabel = bedLabel;Status = status;PatientName = patientName;Demographics = demographics;Team = team;Allergies = allergies;Infection = infection;Alerts = alerts;Edd = edd;DischargeProgress = dischargeProgress;Requests = requests;Ews = ews;WaitingFor = waitingFor;}
        public string BedLabel { get; } public string Status { get; set; } public string PatientName { get; set; } public string Demographics { get; set; } public string Team { get; set; } public string Allergies { get; set; } public string Infection { get; set; } public string Alerts { get; set; } public string Edd { get; set; } public int DischargeProgress { get; set; } public string Requests { get; set; } public int Ews { get; set; } public string WaitingFor { get; set; }
        public bool HasPatient => !string.IsNullOrWhiteSpace(PatientName);
        public string StatusClass => Status.ToLowerInvariant().Replace(" / ", "-").Replace(" ", "-");
        public void Assign(IncomingCard card){PatientName = card.Name; Demographics = "MRN pending"; Team = "General Surgery"; Allergies = "Review on admission"; Status = "Occupied"; WaitingFor = "Admission";}
        public void MarkCleaning(){PatientName = string.Empty; Demographics = string.Empty; Status = "Cleaning"; WaitingFor = "Awaiting cleaning";}
    }
}
