@{
    var navToggleLabel = IsConceptNavCompact
        ? "Expand workspace navigation"
        : "Collapse workspace navigation";
}

<div class="concept-shell">
    <HeaderShell IsDarkMode="IsDarkMode" OnToggleTheme="OnToggleTheme">
        <HeaderContent>
            <button type="button"
                    class="concept-nav-compact-toggle"
                    aria-label="@navToggleLabel"
                    @onclick="OnToggleConceptNavCompact">
                <MudIcon Icon="@(IsConceptNavCompact ? Icons.Material.Outlined.UnfoldMore : Icons.Material.Outlined.UnfoldLess)"
                         Size="Size.Small" />
            </button>

            <ShellModeToggle Mode="CurrentShellMode"
                             OnModeChanged="OnShellModeChanged" />
        </HeaderContent>
    </HeaderShell>

    <MainContentShell>
        @ChildContent
    </MainContentShell>

    <BottomUtilityNavigation IsDarkMode="IsDarkMode" />
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter] public bool IsDarkMode { get; set; }

    [Parameter] public EventCallback OnToggleTheme { get; set; }

    [Parameter] public ShellMode CurrentShellMode { get; set; }

    [Parameter] public EventCallback<ShellMode> OnShellModeChanged { get; set; }

    [Parameter] public bool IsConceptNavCompact { get; set; }

    [Parameter] public EventCallback OnToggleConceptNavCompact { get; set; }
}
