<nav class="primary-nav" aria-label="Primary">
    <div class="primary-nav-track" role="menubar">
        <button type="button" class="home-link @GetSelectedClass("home")" aria-label="Home" @onclick='() => SelectPrimary("home")'>
            <MudIcon Icon="@Icons.Material.Outlined.Home" Size="Size.Small" />
        </button>

        @foreach (var item in PrimaryItems)
        {
            var isActive = item.Key == _activePrimaryKey;
            <button type="button" class="nav-link nav-link-@item.Key @(isActive ? "selected" : null)" @onclick="() => SelectPrimary(item.Key)">
                <span>@item.Label</span>
                @if (item.HasSubMenu)
                {
                    <MudIcon Icon="@Icons.Material.Outlined.ExpandMore" Size="Size.Small" Class="nav-caret" />
                }
            </button>
        }
    </div>

    @if (CurrentSubItems.Count > 0)
    {
        <div class="sub-nav-track" role="menubar" aria-label="Secondary">
            @foreach (var subItem in CurrentSubItems)
            {
                var isSubActive = subItem == _activeSubItem;
                <button type="button" class="sub-nav-link @(isSubActive ? "selected" : null)" @onclick="() => _activeSubItem = subItem"><span>@subItem</span></button>
            }
        </div>
    }
</nav>

@code {
    private readonly List<PrimaryNavItem> PrimaryItems =
    [
        new("myhub", "MyHub", false, []),
        new("hospital", "Hospital Overview", false, []),
        new("dd", "Delayed Discharge", true, ["DD Hub", "Patient Management", "Census Management", "DDP Census"]),
        new("bed", "Bed & Ward", true, ["Bed Hub", "Bed Management"]),
        new("scenario", "Scenario Mapping", false, []),
        new("journey", "Patient Journey", false, []),
        new("apps", "Connected Apps", false, [])
    ];

    private string _activePrimaryKey = "dd";
    private string _activeSubItem = "DD Hub";

    private IReadOnlyList<string> CurrentSubItems => PrimaryItems.First(x => x.Key == _activePrimaryKey).SubItems;

    [Parameter] public bool IsDarkMode { get; set; }

    private void SelectPrimary(string key)
    {
        _activePrimaryKey = key;
        _activeSubItem = CurrentSubItems.FirstOrDefault() ?? string.Empty;
    }

    private string GetSelectedClass(string key) => key == _activePrimaryKey ? "selected" : string.Empty;

    private sealed record PrimaryNavItem(string Key, string Label, bool HasSubMenu, List<string> SubItems);
}
