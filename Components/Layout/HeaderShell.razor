<header class="app-header" role="banner">
    <div class="qld-header-row">
        <div class="qld-brand" aria-label="Queensland Health Patient Flow Hub">
            <img class="qld-logo" src="@(IsDarkMode ? DarkLogoPath : LightLogoPath)" alt="Queensland Government" />
            <div class="qld-divider" aria-hidden="true"></div>
            <div class="qld-title"><strong>QH</strong> Patient Flow Hub</div>
        </div>

        <div class="qld-actions">
            <div class="qld-search" role="search" aria-label="Header search">
                <span class="qld-search-icon" aria-hidden="true">
                    <MudIcon Icon="@Icons.Material.Outlined.Search" Size="Size.Small" />
                </span>
                <input type="search" class="qld-search-input" aria-label="Search" />
                <button type="button" class="qld-search-button">Search</button>
            </div>

            <button class="qld-profile-trigger" type="button" @onclick="OnToggleTheme">
                <div class="qld-avatar" aria-hidden="true"></div>
                <span class="qld-profile-name">Dr Steven Strange</span>
                <MudIcon Icon="@Icons.Material.Outlined.ExpandMore" Size="Size.Small" />
            </button>
        </div>
    </div>

    <PrimaryNavigation IsDarkMode="IsDarkMode" />
</header>

@code {
    private const string LightLogoPath = "images/logos/CoAlight.svg";
    private const string DarkLogoPath = "images/logos/CoAdark.svg";

    [Parameter] public bool IsDarkMode { get; set; }
    [Parameter] public EventCallback OnToggleTheme { get; set; }
}
