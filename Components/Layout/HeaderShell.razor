<header class="app-header @(IsDarkMode ? "theme-dark" : "theme-light")" role="banner">
    <div class="top-header-row">
        <div class="brand-shell" aria-label="Queensland Health Patient Flow Hub">
            <div class="brand-logo-wrap">
                <img class="brand-logo" src="@(IsDarkMode ? DarkLogoPath : LightLogoPath)" alt="Queensland Government" />
            </div>
            <div class="brand-title"><strong>QH</strong> Patient Flow Hub</div>
        </div>

        <div class="header-search-shell" role="search" aria-label="Header search">
            <MudIcon Icon="@Icons.Material.Filled.Search" Size="Size.Small" Class="header-search-icon" />
            <input class="header-search-input" type="search" aria-label="Search" />
            <button class="header-search-button" type="button">Search</button>
        </div>

        <div class="profile-shell">
            <button class="profile-trigger" type="button" @onclick="ToggleProfilePanel" aria-expanded="@_isProfileOpen" aria-label="Open profile menu">
                <div class="profile-avatar" aria-hidden="true">SS</div>
                <span class="profile-name">Dr Steven Strange</span>
                <MudIcon Icon="@(_isProfileOpen ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" Size="Size.Small" />
            </button>

            <div class="profile-panel @(_isProfileOpen ? "open" : null)">
                <button class="profile-panel-item" type="button">Profile</button>
                <button class="profile-panel-item" type="button">Preferences</button>
                <button class="profile-panel-item" type="button" @onclick="ToggleTheme">
                    Theme: @(IsDarkMode ? "Dark" : "Light")
                </button>
                <button class="profile-panel-item" type="button">Sign out</button>
            </div>
        </div>
    </div>

    <PrimaryNavigation IsCollapsed="IsPrimaryNavCollapsed"
                       IsDarkMode="IsDarkMode"
                       OnToggleCollapsed="OnTogglePrimaryNavCollapse" />
</header>

@code {
    private bool _isProfileOpen;

    private const string LightLogoPath = "images/header/qld-logo-light.png";
    private const string DarkLogoPath = "images/header/qld-logo-dark.png";

    [Parameter] public bool IsPrimaryNavCollapsed { get; set; }
    [Parameter] public EventCallback OnTogglePrimaryNavCollapse { get; set; }

    private bool IsDarkMode { get; set; }

    private void ToggleProfilePanel() => _isProfileOpen = !_isProfileOpen;
    private void ToggleTheme() => IsDarkMode = !IsDarkMode;
}
